{
  "name": "@donotdev/expo",
  "version": "0.1.1",
  "type": "module",
  "private": false,
  "description": "React Native/Expo UI components for DoNotDev framework",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./features": {
      "types": "./src/features/index.ts",
      "import": "./src/features/index.ts",
      "default": "./src/features/index.ts"
    }
  },
  "files": [
    "src",
    "package.json",
    "README.md",
    "LICENSE.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/donotdev/expo.git"
  },
  "keywords": [
    "donotdev",
    "dndev",
    "react-native",
    "expo",
    "components",
    "ui",
    "typescript",
    "design-system"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "license": "MIT",
  "scripts": {
    "dev": "tsc --noEmit --watch --listFiles false --listEmittedFiles false",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "type-check": "bunx tsc --noEmit",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@donotdev/core": "workspace:*",
    "@donotdev/crud": "workspace:*",
    "@expo/vector-icons": "^15.0.0",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "^2.1.0",
    "@react-native-community/datetimepicker": "^8.0.0",
    "expo": "^55.0.2",
    "expo-audio": "^1.1.1",
    "expo-av": "^16.0.8",
    "expo-clipboard": "^55.0.8",
    "expo-document-picker": "^55.0.8",
    "expo-router": "^55.0.2",
    "react-hook-form": "^7.71.2",
    "react-native-safe-area-context": "^5.0.0"
  },
  "peerDependencies": {
    "@donotdev/auth": "^0.1.1",
    "@donotdev/billing": "^0.1.1",
    "@donotdev/oauth": "^0.1.1",
    "@donotdev/ui": "^0.1.1",
    "@tanstack/react-query": "^5.0.0",
    "firebase": "^11.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-native": "^0.84.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@donotdev/auth": "workspace:*",
    "@donotdev/billing": "workspace:*",
    "@donotdev/oauth": "workspace:*",
    "@donotdev/ui": "workspace:*",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "jest": "^30.2.0",
    "jest-expo": "^54.0.17",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-native": "^0.84.0",
    "typescript": "5.9.3"
  },
  "peerDependenciesMeta": {
    "@donotdev/auth": {
      "optional": true
    },
    "@donotdev/billing": {
      "optional": true
    },
    "@donotdev/oauth": {
      "optional": true
    },
    "@donotdev/ui": {
      "optional": true
    },
    "firebase": {
      "optional": true
    }
  }
}